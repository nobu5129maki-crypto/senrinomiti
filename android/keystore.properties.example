# このファイルを keystore.properties にコピーして値を設定してください。
# keystore.properties は Git にコミットしないでください。

storeFile=../senrinomiti-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=senrinomiti
keyPassword=YOUR_KEY_PASSWORD

# キーストア作成例（PowerShell / ターミナル）:
# keytool -genkey -v -keystore senrinomiti-release.keystore -alias senrinomiti -keyalg RSA -keysize 2048 -validity 10000
